# Basic binds
super + Return
	$TERMINAL
super + d
	dmen_run
super + r
	$TERMINAL -e lf
super + e
	emacs
super + m
	$TERMINAL -e ncmpcpp
super + n
	$TERMINAL -e emacs
super + y
	$TERMINAL -e htop
super + shift + a
	$TERMINAL -e alsamixer; refbar
super + shift + c
	mpv --no-osc --no-input-default-bindings --input-conf=/dev/null --geometry=640x480-0-0 --title='mpvfloat' /dev/video0
super + shift + e
	$TERMINAL -e neomutt
super + w
	$BROWSER
super + shift + w
	$TERMINAL -e nmtui
super + shift + g
	gimp

# Et cetera...
super + grave
	dmenuunicode
super + Scroll_Lock
	killall screenkey || screenkey
super + Insert
	showclip
super + shift + z
	shutdownmenu
super + shift + x
	prompt "Shutdown computer?" "sudo -A shutdown -h now"
super + shift + BackSpace
	prompt "Reboot computer?" "sudo -A shutdown -h now"
super + x
	mpc pause; pauseallmpv; i3lock -e -f -c 1d2021; xset dpms force off
XF86Launch1
	xset dpms force off
XF86TouchpadToggle
	(synclient | grep "TouchpadOff.*1" && synclient TouchpadOff=0)>/dev/null || synclient TouchpadOff=1
XF86TouchpadOff
	synclient TouchpadOff=1
XF86TouchpadOn
	synclient TouchpadOff=0

# Recording
# Take screenshot
Print
	maim pic-full-$(date '+%y%m%d-%H%M-%S').png
# Pick screenshot type
shift + Print
	maimpick
# Record audio or video
super + Print
	dmenurecord
# kill active recording
super + Delete
	dmenurecord kill

# Pause audio
super + {_,shift +} p
	mpc {toggle,pause}
# Restart track
super + shift + less
	mpc seek 0%
# Seek foward in song
super + {_,shift +} bracketright
	mpc seek +{10,120}
# Seek backward in song
super + {_,shift +} bracketleft
	mpc seek -{10,120}
# Increase volume
super + {equal,plus}
	amixer sset Master {5,15}%+; refbar
# Decrease volume
super {_,shift +} + minus
	amixer sset Master {5,15}%-; refbar

# Function keys
super + F2
	displayselect
# Change display
super + F3
	displayselect
# Hibernate
super + F4
	prompt 'Hibernate computer?' 'sudo systemctl suspend'
# Start torrent daemon/open interface
super + F6
	torwrap
# toggle torrent daemon
super + F7
	td-togggle
# sync email
super + F8
	mailsync
